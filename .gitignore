# =============================================================================
# Escalas Plus — Git ignore
# Mantém no repo: *.example, docker-compose.yml, cloudflare/*.example.yml
# =============================================================================

# --- Dependências Node ---
node_modules/
**/node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/install-state.gz

# --- Build / artefatos compilados ---
dist/
**/dist/
build/
**/build/
out/
**/out/
*.tsbuildinfo

# --- Next.js ---
.next/
**/.next/
out/
next-env.d.ts.bak

# --- Variáveis de ambiente e segredos ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
# Qualquer .env.* exceto templates versionados
**/.env.*
!**/.env.example
!**/.env.*.example
!.env.example

# --- Cloudflare Tunnel (credenciais locais; não commitar) ---
.cloudflared/
**/.cloudflared/
cloudflare/config.yml
!cloudflare/config.example.yml
!cloudflare/**/*.example.yml

# --- WhatsApp (Baileys) — sessão e dados locais ---
backend/data/
**/whatsapp-auth/
*.session

# --- Logs ---
logs/
**/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Testes e cobertura ---
coverage/
.nyc_output/
*.lcov
.jest/

# --- Cache de ferramentas ---
.cache/
**/.cache/
.parcel-cache/
.eslintcache
.turbo/
.vercel/
.swc/

# --- Banco / backups (nunca versionar dumps) ---
pgdata/
**/pgdata/
*.sql.gz
*.dump
/backups/
**/backups/

# --- Docker (somente overrides locais) ---
docker-compose.override.yml
docker-compose.*.local.yml
.docker/

# --- Certificados e chaves ---
*.pem
*.key
*.p12
*.pfx
.credentials/
**/secrets/

# --- Sistema operacional ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- IDEs / editores ---
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.project
.classpath
.settings/
*.code-workspace

# VS Code — descomente para ignorar config local da equipe
# .vscode/
# !.vscode/extensions.json

# Cursor — descomente se não quiser versionar regras locais
# .cursor/

# --- Misc ---
*.tgz
*.orig
*.bak
tmp/
temp/
